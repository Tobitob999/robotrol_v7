# Normalize line endings to LF in the repo
* text=auto eol=lf

# Force LF for text files
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.spec text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.exe binary
*.pyc binary
